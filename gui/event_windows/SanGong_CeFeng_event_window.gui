							# 	margin = { 2 2 }
							# }
						}
					}
				}

				widget = {
					name = "char_toggles_widget"
					parentanchor = top|right
					position = { -35 20 }
					size = { 35 35 }
		
					icon = {
						size = { 35 35 }
						texture = "gfx/interface/window_domiciles/domicile_window_control_background.dds"
						spriteType = Corneredtiled
						spriteborder = { 35 10 }
						texture_density = 2
					}
		
					hbox = {
						name = "ui_toggles"
						spacing = 5
		
						margin = { 0 0 }
		
		
						button = {
							# visible = "[Not( GetVariableSystem.Exists( 'clear_char_hide' ) )]"
							visible = "[Not(GetPlayer.MakeScope.Var('clear_char_hide').IsSet)]"
							size = { 30 30 }
							texture = "gfx/interface/icons/flat_icons/hide_ui.dds"
		
							# onclick = "[GetVariableSystem.Toggle( 'clear_char_hide' )]"
							onclick = "[GetScriptedGui('futa_toggle_char_button').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		
							tooltip = "HIDE_CHAR_BUTTON_TEXT_HIDE"
		
							# background = {
							# 	using = Background_Area_Dark
							# 	margin = { 2 2 }
							# }
						}
		
						button = {
							# visible = "[GetVariableSystem.Exists( 'clear_char_hide' )]"
							visible = "[GetPlayer.MakeScope.Var('clear_char_hide').IsSet]"
							size = { 30 30 }
							texture = "gfx/interface/icons/flat_icons/observer.dds"
		
							# onclick = "[GetVariableSystem.Toggle( 'clear_char_hide' )]"
							onclick = "[GetScriptedGui('futa_toggle_char_button').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		
							tooltip = "HIDE_CHAR_BUTTON_TEXT_SHOW"
		
