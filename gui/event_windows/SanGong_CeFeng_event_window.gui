							# visible = "[GetVariableSystem.Exists( 'clear_ui_hide' )]"
							visible = "[GetPlayer.MakeScope.Var('clear_ui_hide').IsSet]"
							size = { 30 30 }
							texture = "gfx/interface/icons/flat_icons/observer.dds"
		
							# onclick = "[GetVariableSystem.Toggle( 'clear_ui_hide' )]"
							onclick = "[GetScriptedGui('futa_toggle_ui_button').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
		
