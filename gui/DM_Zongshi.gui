            widget = {# 皇子公主
                background = {
                    # texture = "gfx/interface/illustrations/event_scenes/tgp_courtyard_asia.dds"
                    alpha = 1
                    fittype = centercrop
                }
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding
                visible = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_12' )]"

                scrollbox = {
                    size = { 100% 100% }
                    blockoverride "scrollbox_content" {
                        hbox = {
                            margin = { 0 10 }
                            ignoreinvisible = no
                            spacing = 45
                            vbox = {
                                ignoreinvisible = no
