

window = {#后宫
    name = "DM_Zongshi_Main"
    #datacontext = "[GetPlayer.GetPrimaryTitle]"
    #datacontext = "[GetVariableSystem]"
	datacontext = "[GetPlayer]"
    visible = "[GetVariableSystem.HasValue( 'SanGong_HouGong_open', 'true' )]"
    #visible = "[GetVariableSystem.Exists( 'SanGong_HouGong_open' )]"
    parentanchor = top|center
    position = { 0 5% } 
    size = { 1200 1000 }
    minimumsize = { 600 100 }
    layer = windows_layer 
    movable = yes
    using = Window_Background
    using = Window_Decoration
    state = {
        name = _show
        using = Animation_FadeIn_Standard
        on_start = "[GetVariableSystem.Set( 'SanGong_ZongShi_Main', 'Page_1' )]"
    }
    state = {
        name = _hide
        using = Animation_FadeOut_Standard
    }

    vbox = {
        using = Window_Margins
        header_pattern = {
            visible = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_1' )]"
            layoutpolicy_horizontal = expanding

            blockoverride "header_text"
            {
                text = "DM_GongShi_Main_name" 
            }
            blockoverride "button_close"
            {
                onclick = "[GetVariableSystem.Toggle( 'SanGong_HouGong_open' )]"
                onclick = "[GetScriptedGui('HouGong_close_guis').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
                
            }
        }
        header_pattern = {
            visible = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_2' )]"
            layoutpolicy_horizontal = expanding

            blockoverride "header_text"
            {
                text = "DM_WangShi_Main_name" 
            }
            blockoverride "button_close"
            {
                onclick = "[GetVariableSystem.Toggle( 'SanGong_HouGong_open' )]"
                onclick = "[GetScriptedGui('clear_variable_Zongshi_guis').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
            }
        }
        DM_view = {
           # visible = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_1' )]"
        }
      # DM_dependentRuler_view = {     
      #     visible = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_2' )]"

      # }
        scrollarea = {
            layoutpolicy_horizontal = expanding
            size = { 0 60 } 
           # visible = "[And( LessThan_int32( GetPlayer.GetPrimaryTitle.GetTierFrame, '(int32)6' ), Not( GetPlayer.IsIndependentRuler ) )]"  # 非独立且头衔<皇帝
            scrollbarpolicy_horizontal = always_off 
            scrollbarpolicy_vertical = always_off
            scrollbar_horizontal = { using = Scrollbar_Horizontal }
            scrollwidget = {
                flowcontainer = {
                    direction = horizontal
                    spacing = 2
                    margin = { 40 0 }
                    button_tab = {
                        size = { 550 55 } 
                        down = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_1' )]"
                        onclick = "[GetVariableSystem.Set( 'SanGong_ZongShi_Main', 'Page_1' )]"                                              
                        text_single = { 
                            parentanchor = center 
                            text = "DM_Gongshi_main"	        				
                            fontsize = 18
                        }
                    }
                    button_tab = {# 
                        size = { 550 55 }
                        down = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_2' )]"
                        onclick = "[GetVariableSystem.Set( 'SanGong_ZongShi_Main', 'Page_2' )]"                                              
                        text_single = { 
                            parentanchor = center 
                            text = "DM_Wangshi_main"			
                            fontsize = 18
                        }
                    }
                    
                }
            }
        }

        vbox = {
            layoutpolicy_horizontal = expanding
            layoutpolicy_vertical = expanding  
            widget = {  #公室
                layoutpolicy_horizontal = expanding
                layoutpolicy_vertical = expanding
                visible = "[GetVariableSystem.HasValue( 'SanGong_ZongShi_Main', 'Page_1' )]"
                scrollbox = {
                    size = { 100% 100% }
                    blockoverride "scrollbox_content"
                    {
                        
                    hbox = {
                        layoutpolicy_horizontal = expanding
                        margin = { 20 5 }
                        spacing = 10
                        
                        divider_light = {
                            size = { 0 5 }     
                            layoutpolicy_horizontal = expanding
                            color = { 1.0 0.0 0.0 0.6 }
                        }
                       button_frontend = {
                            text = "DM_Zongshi_qiqie_btn"
                            visible = "[Not(GetVariableSystem.Exists('DM_Zongshi_qiqie'))]"
                            tooltip = "DM_Zongshi_qiqie_btn_tt"
                            onclick = "[GetVariableSystem.Set('DM_Zongshi_qiqie', 'yes')]"
                            onclick = "[GetVariableSystem.Clear('DM_Zongshi_zinv')]"
                        }
                        button_frontend = {
                            text = "DM_Zongshi_zinv_btn"
                            visible = "[GetVariableSystem.Exists('DM_Zongshi_qiqie')]"
                            tooltip = "DM_Zongshi_zinv_btn_tt"
                            onclick = "[GetVariableSystem.Clear('DM_Zongshi_qiqie')]"
                            onclick = "[GetVariableSystem.Set('DM_Zongshi_zinv', 'yes')]"
                        }
                        divider_light = {
                            layoutpolicy_horizontal = expanding  
                            color = { 1.0 0.0 0.0 0.6 }
                        }
                    }
                    hbox = {#妻妾
                        visible = "[Not(GetVariableSystem.Exists('DM_Zongshi_qiqie'))]"
                        layoutpolicy_vertical = expanding
                        dynamicgridbox = {
                            datamodel = "[GetPlayer.MakeScope.GetList('Gongshi_pinfei_list')]"
                            layoutpolicy_horizontal = expanding
                            layoutpolicy_vertical = expanding
                            datamodel_wrap = 5
                            flipdirection = yes
                            item = {
                                portrait_shoulders = {
                                    datacontext = "[Scope.GetCharacter]"
                                    size = { 220 180 }
                                    blockoverride "highlight_icon" {}
                                    blockoverride "opinion_box" {}
                                    blockoverride "status_icons" {}
                                    flowcontainer = {#信息概览
                                        parentanchor = top|right
                                        position = { -30 30 }
                                        direction = vertical
                                        spacing = -2
                                        flowcontainer = {
                                            text_single = {
                                                text = "SanGong_view_age"
                                                fontsize = 14
                                                alpha = 0.5
                                                align = nobaseline
                                            }
                                            tooltip = "DM_Qiqie_TT"
                                        }
                                        flowcontainer = {
                                            text_single = {
                                                visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'pregnant' ) ) )]"
                                                text = "Huaiyun_text"
                                                align = nobaseline
                                                tooltip = "Huaiyun_text_tt"
                                            }                                         
                                        }
                                    } 
                                    flowcontainer = {
                                        parentanchor = bottom|hcenter
                                        position = { 10 20 }
                                        spacing = 2
                                            flowcontainer = {
                                                text_single = {
                                                text = "DM_Qiqie_Name"
                                                fontsize = 20
                                                max_width = 200
                                                align = nobaseline

                                            }
                                        }
                                        flowcontainer = {
                                            icon = {
                                                size = { 33 33 }
                                                framesize = { 60 60 }
                                                frame = "[Character.GetHealthIconFrame]"
                                                texture = "gfx/interface/icons/character_status/icon_health.dds"
                                                tooltip = "DM_Qiqie_TT"
                                            }                                            
                                        }
                                    }
                                    
                                }
                            }
                        }
                    }
                    hbox = {#子女
                        visible = "[GetVariableSystem.Exists('DM_Zongshi_qiqie')]"
                        vbox = {
                                ignoreinvisible = no
                                layoutpolicy_vertical = expanding

                                text_label_center = {
                                    text = "DM_Gongshi_male"
                                    using = Font_Size_Medium
                                    default_format = "#high"
                                    align = nobaseline
                                }
                                dynamicgridbox = {#子
                                    datamodel = "[GetPlayer.MakeScope.GetList('child_male_list')]"
                                    layoutpolicy_horizontal = expanding
                                    layoutpolicy_vertical = expanding
                                    datamodel_wrap = 4
                                    flipdirection = yes
                                    item = {
                                        portrait_shoulders = {
                                            datacontext = "[Scope.GetCharacter]"
                                            size = { 130 150 }
                                            blockoverride "portrait_size" {
                                                size = { 105 135 } 
                                            }
                                            flowcontainer = {
                                                parentanchor = top|right
                                                position = { 0 30 }
                                                direction = vertical
                                                spacing = -2
                                                flowcontainer = {
                                                    text_single = {
                                                        text = "SanGong_view_age"
                                                        fontsize = 14
                                                        alpha = 0.5
                                                        align = nobaseline
                                                    }
                                                    tooltip = "DM_Qiqie_TT"
                                                }
                                            }
                                            text_single = {
                                                parentanchor = bottom|center
                                                text = "DM_Gongshi_male_Name"
                                                margin_top = 150
                                                fontsize_min = 14
                                                fontsize = 18
                                                max_width = 120
                                                align = nobaseline
                                            }
                                            
                                            blockoverride "coa" {}
                                            blockoverride "highlight_icon" {}
                                            blockoverride "opinion_box" {}
                                            blockoverride "status_icons" {}
                                        }
                                    }
                                }
                            }

                            divider = {
                                layoutpolicy_vertical = expanding
                                color = { 1.0 0.0 0.0 0.6 }
                            }

                            vbox = {
                                ignoreinvisible = no
                                layoutpolicy_vertical = expanding

                                text_label_center = {
                                    text = "DM_Gongshi_female"
                                    using = Font_Size_Medium
                                    default_format = "#high"
                                    align = nobaseline
                                }

                                dynamicgridbox = {#女
                                    datamodel = "[GetPlayer.MakeScope.GetList('child_female_list')]"
                                    layoutpolicy_horizontal = expanding
                                    layoutpolicy_vertical = expanding
                                    datamodel_wrap = 4
                                    flipdirection = yes
                                    item = {
                                        portrait_shoulders = {
                                            datacontext = "[Scope.GetCharacter]"
                                            size = { 130 150 }
                                            blockoverride "portrait_size" {
                                                size = { 105 135 } 
                                            }
                                            flowcontainer = {#信息概览
