                                                direction = vertical
                                                spacing = -2
                                                flowcontainer = {
                                                    text_single = {
                                                        text = "SanGong_view_age"
                                                        fontsize = 14
                                                        alpha = 0.5
                                                        align = nobaseline
                                                    }
                                                    tooltip = "DM_Qiqie_TT"
                                                }
                                                flowcontainer = {
                                                    text_single = {
                                                        visible = "[GetScriptedGui('ChuGe_GuiS').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
                                                        text = "ChuGe_TEXT"
                                                        fontsize = 14
                                                        align = nobaseline
                                                        tooltip = "ChuGe_TEXT_TT"
                                                    }
                                                }
                                                flowcontainer = {
                                                    text_single = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'pregnant' ) ) )]"
                                                        text = "Huaiyun_text"
                                                        align = nobaseline
                                                        tooltip = "Huaiyun_text_tt"
                                                    }                                         
                                                }
                                            } 
                                            flowcontainer = {#信息概览
                                                parentanchor = top|left
                                                position = { 0 30 }
                                                direction = horizontal
                                                spacing = -2
                                                flowcontainer = {
                                                    icon = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'incestuous' ) ) )]"
                                                        size = { 33 33 }
                                                        texture = "gfx/interface/icons/traits/incestuous.dds"
                                                        align = nobaseline
                                                        tooltip = "trait_incestuous_desc"
                                                    }                                         
                                                }
                                                flowcontainer = {
                                                    icon = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'fornicator' ) ) )]"
                                                        size = { 33 33 }
                                                        texture = "gfx/interface/icons/traits/fornicator.dds"
                                                        align = nobaseline
                                                        tooltip = "trait_fornicator_desc"
                                                    }                                         
                                                }
                                                flowcontainer = {
                                                    icon = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'adulterer' ) ) )]"
                                                        size = { 33 33 }
                                                        texture = "gfx/interface/icons/traits/adulterer.dds"
                                                        align = nobaseline
                                                        tooltip = "trait_adulterer_desc"
                                                    }                                         
                                                }
                                            } 
                                            text_single = {
                                                parentanchor = bottom|center
                                                text = "DM_Gongshi_female_Name"
                                                margin_top = 150
                                                margin_left = 0
                                                fontsize_min = 12
                                                fontsize = 16
                                                max_width = 120
                                                default_format = "#difficulty_medium"
                                                align = nobaseline
                                            }
                                            flowcontainer = {#信息概览
                                                parentanchor = bottom|left
                                                position = { 0 0 }
                                                direction = vertical
                                                spacing = -2
                                                flowcontainer = {
                                                    button = {
                                                        name = "XunGuiLianYin_interaction"
                                                        #parentanchor = bottom|left
                                                        size = { 30 30 }
                                                        #position = { 0 0 }
                                                        texture = "gfx/interface/icons/scheme_types/icon_scheme_seduce.dds"
                                                        datacontext = "[GetScriptedGui( 'XunGuiLianYin_interaction' )]"
                                                        visible = "[Character.IsPlayerInteractionShown('XunGuiLianYin_interaction')]"
                                                        #visible = "[Character.IsPlayerInteractionValid('XunGuiLianYin_interaction')]"
                                                        onclick = "[Character.OpenPlayerInteraction('XunGuiLianYin_interaction')]"
                                                        tooltip = "[Character.GetPlayerInteractionTooltip('XunGuiLianYin_interaction')]"
                                                    }

                                                }
                                            } 

                                            blockoverride "coa" {}
                                            blockoverride "highlight_icon" {}
                                            blockoverride "opinion_box" {}
                                            blockoverride "status_icons" {}
                                        }
                                    }
                                }
                            }
                    }
                    }
                }
            }
