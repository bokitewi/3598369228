                                        trigger_on_create = yes
                                        duration = 2
                                        on_start = "[GetScriptedGui('SanGong_HuangZi_gui').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
                                        next = get_list
                                    }
                                    item = {
                                        portrait_shoulders = {
                                            datacontext = "[Scope.GetCharacter]"
                                            size = { 130 150 }
                                            blockoverride "portrait_size" {
                                                size = { 105 135 } 
                                            }
                                            flowcontainer = {
                                                parentanchor = top|right
                                                position = { 0 30 }
                                                direction = vertical
                                                spacing = -2
                                                flowcontainer = {
                                                    text_single = {
                                                        text = "SanGong_view_age"
                                                        fontsize = 14
                                                        alpha = 0.5
                                                        align = nobaseline
                                                    }
                                                    tooltip = "SanGong_CHARACTER_VIEW_AGE_TT"
                                                }
                                            }
                                            text_single = {
                                                text = "#v #bold [Character.Custom('SanGong_view_name_HuangziGui')]"
                                                margin_top = 150
                                                margin_left = 10
                                                fontsize_min = 14
                                                fontsize = 18
                                                max_width = 120
                                                align = nobaseline
                                            }

                                            button = {
                                                name = "Cefeng_ZongShi_interaction"
                                                parentanchor = bottom|left
                                                size = { 30 30 }
                                                texture = "gfx/interface/icons/traits/loyal.dds"
                                                datacontext = "[GetScriptedGui( 'ZongWang_gui' )]"
                                                visible = "[Character.IsPlayerInteractionShown('Cefeng_ZongShi_interaction')]"
                                                onclick = "[ScriptedGui.Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).AddScope( 'recipient', Character.MakeScope ).End  )]"
                                                tooltip = "[Character.GetPlayerInteractionTooltip('Cefeng_ZongShi_interaction')]"
                                            }
                                            button = {
                                                name = "ChiDuo_ZongWang_interaction"
                                                parentanchor = bottom|left
                                                size = { 30 30 }
                                                position = { 0 0 }
                                                texture = "gfx/interface/icons/character_interactions/icon_governor_removal.dds"
                                                datacontext = "[GetScriptedGui( 'ChiDuo_ZongWang_interaction' )]"
                                                visible = "[Character.IsPlayerInteractionValid('ChiDuo_ZongWang_interaction')]"
                                                onclick = "[Character.OpenPlayerInteraction('ChiDuo_ZongWang_interaction')]"
                                                tooltip = "[Character.GetPlayerInteractionTooltip('ChiDuo_ZongWang_interaction')]"
                                            }
                                            button = {
                                                name = "SanGong_HuangziJiuFan_interaction"
                                                parentanchor = bottom|left
                                                size = { 30 30 }
                                                position = { 0 -60 }
                                                texture = "gfx/interface/icons/scheme_types/mentor.dds"
                                                datacontext = "[GetScriptedGui( 'SanGong_HuangziJiuFan_interaction' )]"
                                                visible = "[Character.IsPlayerInteractionShown('SanGong_HuangziJiuFan_interaction')]"
                                                onclick = "[Character.OpenPlayerInteraction('SanGong_HuangziJiuFan_interaction')]"
                                                tooltip = "[Character.GetPlayerInteractionTooltip('SanGong_HuangziJiuFan_interaction')]"
                                            }
                                            
                                            blockoverride "coa" {}
                                            blockoverride "highlight_icon" {}
                                            blockoverride "opinion_box" {}
                                            blockoverride "status_icons" {}
                                        }
                                    }
                                }
                            }

                            divider = {
                                layoutpolicy_vertical = expanding
                                color = { 1.0 0.0 0.0 0.6 }
                            }

                            vbox = {
                                ignoreinvisible = no
                                layoutpolicy_vertical = expanding

                                text_label_center = {
                                    text = "SanGong_Princess"
                                    using = Font_Size_Medium
                                    default_format = "#high"
                                    align = nobaseline
                                }

                                dynamicgridbox = {
                                    datamodel = "[GetPlayer.MakeScope.GetList('SanGong_GongZhu')]"
                                    layoutpolicy_horizontal = expanding
                                    layoutpolicy_vertical = expanding
                                    datamodel_wrap = 4
                                    flipdirection = yes
                                    state = {
                                        name = get_list
                                        trigger_on_create = yes
                                        duration = 2
                                        on_start = "[GetScriptedGui('SanGong_GongZhu_gui').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
                                        next = get_list
                                    }
                                    item = {
                                        portrait_shoulders = {
                                            datacontext = "[Scope.GetCharacter]"
                                            size = { 130 150 }
                                            blockoverride "portrait_size" {
                                                size = { 105 135 } 
                                            }
                                            flowcontainer = {#信息概览
                                                parentanchor = top|right
                                                position = { 0 30 }
                                                direction = vertical
                                                spacing = -2
                                                flowcontainer = {
                                                    text_single = {
                                                        text = "SanGong_view_age"
                                                        fontsize = 14
                                                        alpha = 0.5
                                                        align = nobaseline
                                                    }
                                                    tooltip = "SanGong_CHARACTER_VIEW_AGE_TT"
                                                }
                                                flowcontainer = {
                                                    text_single = {
                                                        visible = "[GetScriptedGui('ChuGe_GuiS').IsShown(GuiScope.SetRoot(Character.MakeScope).End)]"
                                                        text = "ChuGe_TEXT"
                                                        fontsize = 14
                                                        align = nobaseline
                                                        tooltip = "ChuGe_TEXT_TT"
                                                    }
                                                }
                                                flowcontainer = {
                                                    text_single = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'pregnant' ) ) )]"
                                                        text = "Huaiyun_text"
                                                        align = nobaseline
                                                        tooltip = "Huaiyun_text_tt"
                                                    }                                         
                                                }
                                            } 
                                            flowcontainer = {#信息概览
                                                parentanchor = top|left
                                                position = { 0 30 }
                                                direction = horizontal
                                                spacing = -2
                                                flowcontainer = {
                                                    icon = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'incestuous' ) ) )]"
                                                        size = { 33 33 }
                                                        texture = "gfx/interface/icons/traits/incestuous.dds"
                                                        align = nobaseline
                                                        tooltip = "trait_incestuous_desc"
                                                    }                                         
                                                }
                                                flowcontainer = {
                                                    icon = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'fornicator' ) ) )]"
                                                        size = { 33 33 }
                                                        texture = "gfx/interface/icons/traits/fornicator.dds"
                                                        align = nobaseline
                                                        tooltip = "trait_fornicator_desc"
                                                    }                                         
                                                }
                                                flowcontainer = {
                                                    icon = {
                                                        visible = "[And( Not( Character.IsPlayer ), Character.HasTrait( GetTrait( 'adulterer' ) ) )]"
                                                        size = { 33 33 }
                                                        texture = "gfx/interface/icons/traits/adulterer.dds"
                                                        align = nobaseline
                                                        tooltip = "trait_adulterer_desc"
                                                    }                                         
                                                }
                                            } 
                                            text_single = {
                                                text = "[Character.Custom('SanGong_view_name_GongTing')]"
                                                margin_top = 150
                                                margin_left = 0
                                                fontsize_min = 12
                                                fontsize = 16
                                                max_width = 120
                                                default_format = "#difficulty_medium"
                                                align = nobaseline
                                            }
                                            flowcontainer = {#信息概览
                                                parentanchor = bottom|left
                                                position = { 0 0 }
                                                direction = vertical
                                                spacing = -2
                                                flowcontainer = {
                                                    button = {
                                                        name = "XunGuiLianYin_interaction"
                                                        #parentanchor = bottom|left
                                                        size = { 30 30 }
                                                        #position = { 0 0 }
                                                        texture = "gfx/interface/icons/scheme_types/icon_scheme_seduce.dds"
                                                        datacontext = "[GetScriptedGui( 'XunGuiLianYin_interaction' )]"
                                                        visible = "[Character.IsPlayerInteractionShown('XunGuiLianYin_interaction')]"
                                                        #visible = "[Character.IsPlayerInteractionValid('XunGuiLianYin_interaction')]"
                                                        onclick = "[Character.OpenPlayerInteraction('XunGuiLianYin_interaction')]"
                                                        tooltip = "[Character.GetPlayerInteractionTooltip('XunGuiLianYin_interaction')]"
                                                    }

                                                }
                                            } 

                                            blockoverride "coa" {}
                                            blockoverride "highlight_icon" {}
                                            blockoverride "opinion_box" {}
                                            blockoverride "status_icons" {}
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

        }
    }
}
