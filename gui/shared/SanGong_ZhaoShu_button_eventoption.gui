

types SanGong_ZhaoShu_button_eventoption
{
    # 继承自标准事件选项按钮
    type SanGong_ZhaoShu_button_eventoption = button_event_standard
    {
        # ---- 基础按钮属性 ----
        name = "event_option_button"                        # 按钮名称标识
        block "button_size" {
            size = { 200 200 }                               # 按钮默认尺寸（宽×高）
        }
        enabled = "[EventOption.IsValid]"                   # 仅当选项有效时可点击

        # ---- 音效 ----
        default_clicksound = "event:/SFX/UI/Generic/sfx_ui_generic_icon_select"  # 默认点击音效
        onclick = "[EventOption.Select]"                    # 点击时执行选项选择逻辑
        clicksound = "[EventOption.GetClickSound]"          # 动态获取点击音效（不同选项可能不同）

        # ---- 折叠/展开状态（用于tooltip） ----
        block "eventoption_down" {
            down = "[And(GetVariableSystem.HasValue('event_tooltip', EventOption.GetText), PdxGuiFoldOut.IsUnfolded)]"
            # 条件：当变量系统中有对应的事件tooltip文本，且折叠面板已展开时，按钮保持按下状态
            # 目的：点击后展开详细说明面板，视觉上按钮保持"按下"以表示激活
        }

        # ---- 快捷键绑定 ----
        # shift: 快速选择选项
        button_event_shortcut = {}

        # alt: 预览选项效果
        button_event_preview = {}

        # ---- 鼠标悬停回调 ----
        block "onmousehierarchy_callbacks" {
            onmousehierarchyenter = "[EventOption.OnEnter]"   # 鼠标进入时触发
            tooltip = "ZhaoShu_UI_TT"       
            onmousehierarchyleave = "[EventOption.OnLeave]"   # 鼠标离开时触发
        }

        # ---- 按钮背景图标 ----
        icon = {
            texture = "gfx/interface/icons/court_position_types/HuangDiZhiBao.dds"
            alpha = 1                                           # 完全不透明
            spriteType = Corneredtiled                           # 九宫格拉伸（可自适应大小）
            #spriteborder = { 3 3 }                              # 九宫格边框宽度
            framesize = { 200 200 }                               # 单帧原始尺寸
            size = { 100% 100% }                                 # 填充整个按钮区域

            # 水平渐变遮罩（使按钮左右两侧淡出）
            modify_texture = {
                name = "mask"         
                alpha = 0.1                           # 遮罩名称
                texture = "gfx/interface/icons/court_position_types/keeper_of_the_harem_court_position.dds"
                spriteType = Corneredtiled                        # 九宫格拉伸
                spriteborder_left = 40                            # 左侧不淡出区域（保护左侧内容）
                spriteborder_right = 40                           # 右侧不淡出区域（保护右侧内容）
                blend_mode = alphamultiply                        # Alpha乘法混合模式（实现淡出效果）
            }
        }

        # ====================================================================
        # 提示文本容器（防止选项文本抢走特性/技能图标的tooltip）
        # ====================================================================
        hbox = {
            # 快捷键提示
            tooltip = "EVENT_TOOLTIP_SHORTCUT"                   # 显示快捷键说明
            tooltip_visible = "[Not( StringIsEmpty( EventOption.GetTooltip ) )]"  # 仅在有额外提示时显示

            # 提示框位置偏移
            block "option_tooltip_position"
            {
                using = tooltip_ws                                # 引用标准tooltip窗口设置
                tooltip_offset = { 100 0 }                        # 向左偏移80像素
            }

            # 效果预览tooltip
            tooltipwidget = {
                using = DefaultTooltipWidget                      # 使用默认tooltip控件
            }
        }

        # ---- 按钮整体水平渐变遮罩（与内部icon一致） ----
        modify_texture = {
            name = "mask"
            texture = "gfx/interface/icons/court_position_types/keeper_of_the_harem_court_position.dds"
            spriteType = Corneredtiled
            spriteborder_left = 40
            spriteborder_right = 40
            blend_mode = alphamultiply
        }

        # ---- 特殊选项动画效果 ----
        # 特殊选项（如获得金钱/威望等有利事件）— 金色/蓝色光芒
        animation_glow_event = {
            name = "special_option"
            visible = "[And(EventOption.HasFlag('special'), Not(EventOption.HasFlag('dangerous')))]"
            # 条件：标记为"special"且非"dangerous"
        }

        # 危险选项（如死亡、失去领土等不利事件）— 红色光芒
        animation_glow_event = {
            name = "dangerous_option"
            visible = "[EventOption.HasFlag('dangerous')]"      # 标记为"dangerous"
            using = Color_Red                                   # 使用红色配色
        }

        # ====================================================================
        # 按钮内部内容区域（水平布局）
        # ====================================================================
        hbox = {
            margin = { 5 0 }                                    # 左右留白5像素

            # ---- 快捷键编号显示（1/2/3等） ----
            widget_event_shortcut = {}

            # ---- 理由图标 + 超时警告图标 ----
            hbox = {
                # 理由图标网格（显示AI选择该选项的原因图标，如"获取金钱"、"威慑"等）
                fixedgridbox = {
                    name = "reason_icons"
                    datamodel = "[EventOption.Reasons]"          # 数据源：选项理由列表
                    addcolumn = 34                               # 每列宽度34px
                    addrow = 34                                  # 每行高度34px
                    flipdirection = yes                          # 从左到右、从上到下排列
                }

                # 超时警告图标（多人模式下，选项剩余时间≤30天时显示倒计时图标）
                warning_icon = {
                    visible = "[And( EventOption.IsTimeoutOption, And( GameHasMultiplePlayers, LessThanOrEqualTo_int32( EventWindowData.GetDaysRemaining, '(int32)30' ) ) )]"
                    name = "timeout_icon"
                    size = { 30 30 }
                    tooltip = EVENT_WINDOW_DAYS_REMAINING        # 显示剩余天数提示
                }
            }

            # ================================================================
            # 效果占位符（用于对齐，确保效果图标区域占据固定空间）
            # ================================================================
            hbox = {
                name = "spacer_effects"
                datamodel = "[EventOption.Effects]"              # 数据源：选项效果列表

                item = {
                    container = {
                        # 特性占位
                        container = {
                            visible = "[OptionEffectItem.IsTrait]"  # 是特性效果
                            alwaystransparent = yes                 # 允许穿透点击（不拦截鼠标事件）

                            spacer = {
                                datacontext = "[OptionEffectItem.GetTrait]"  # 设置数据上下文为特性
                                size = { 34 34 }
                            }
                        }

                        # 压力值占位
                        spacer = {
                            visible = "[OptionEffectItem.IsStress]"
                            size = { 34 34 }
                        }

                        # 阴谋占位
                        spacer = {
                            visible = "[OptionEffectItem.IsScheme]"
                            size = { 34 34 }
                        }

                        # 死亡占位
                        spacer = {
                            visible = "[OptionEffectItem.IsDeath]"
                            size = { 34 34 }
                        }
                    }
                }
            }

            # ---- 选项文本（居中显示，自适应字号） ----
            text_single = {
                layoutpolicy_horizontal = expanding             # 水平自动扩展（已注释）
                margin_left = 0
                #margin_top = -5                                 # 垂直微调（已注释）
                alwaystransparent = yes                          # 允许穿透点击（不拦截按钮点击事件）
               
                default_format = "#v #bold"                      # 高亮样式：#v = 变量颜色，#bold = 粗体
                align = center|nobaseline                        # 水平居中，不使用基线对齐
                fontsize_min = 12                                # 最小字号12（防止文本过长时缩得太小）
                fontsize = 30                                    # 默认字号20
            }

            # ================================================================
            # 右侧占位区（与左侧理由图标对称，保持布局平衡）
            # ================================================================
            # 快捷键编号占位（右侧留空，与左侧占位对称）
            widget_event_shortcut_base = {}

            hbox = {
                # 理由图标占位（右侧，与左侧reason_icons对称）
                hbox = {
                    name = "reason_spacers"
                    datamodel = "[EventOption.Reasons]"

                    item = {
                        spacer = {
                            size = { 34 34 }                    # 与左侧理由图标尺寸一致
                        }
                    }
                }

                # 超时图标占位（右侧，与左侧timeout_icon对称）
                hbox = {
                    name = "timeout_spacer"
                    visible = "[And( EventOption.IsTimeoutOption, And( GameHasMultiplePlayers, LessThanOrEqualTo_int32( EventWindowData.GetDaysRemaining, '(int32)30' ) ) )]"

                    spacer = {
                        size = { 34 34 }
                    }
                }
            }

            # ================================================================
            # 效果图标网格（实际显示效果图标，两列排列）
            # ================================================================
            hbox = {
                name = "effects_grid"
                datamodel = "[EventOption.Effects]"
                datamodel_wrap = 2                               # 每行最多2个图标

                item = {
                    container = {
                        # ---- 特性效果图标 ----
                        container = {
                            visible = "[OptionEffectItem.IsTrait]"
                            datacontext = "[OptionEffectItem.GetTrait]"   # 切换到特性数据上下文
                            alwaystransparent = yes

                            # 为tooltip切换上下文到玩家角色的信仰（特性tooltip需要）
                            datacontext = "[GetPlayer]"
                            datacontext = "[GetPlayer.GetFaith]"

                            # 特性详情tooltip
                            tooltipwidget = {
                                using = character_trait_tooltip  # 引用角色特性提示控件
                            }

                            # 特性图标
                            icon = {
                                name = "trait_icon"
                                size = { 34 34 }
                                texture = "[Trait.GetIcon(GetPlayer)]"  # 获取玩家角色的特性图标
                            }

                            # 获得特性标记（+号）
                            icon = {
                                visible = "[OptionEffectItem.IsGain]"
                                texture = "gfx/interface/icons/symbols/icon_plus_small.dds"
                                name = "gain"
                                size = { 20 20 }
                            }

                            # 失去特性标记（-号）
                            icon = {
                                visible = "[OptionEffectItem.IsLoss]"
                                texture = "gfx/interface/icons/symbols/icon_minus_small.dds"
                                name = "loss"
                                size = { 20 20 }
                            }
                        }

                        # ---- 压力值效果图标 ----
                        container = {
                            visible = "[OptionEffectItem.IsStress]"
                            alwaystransparent = yes

                            # 压力增加（普通）
                            icon = {
                                visible = "[And(OptionEffectItem.IsGain,Not(OptionEffectItem.IsCritical))]"
                                texture = "gfx/interface/icons/stress/icon_stress_gain.dds"
                                name = "stress_gain"
                                size = { 34 34 }
                            }

                            # 压力减少
                            icon = {
                                visible = "[OptionEffectItem.IsLoss]"
                                texture = "gfx/interface/icons/stress/icon_stress_loss.dds"
                                name = "stress_loss"
                                size = { 34 34 }
                            }

                            # 压力暴增（致命级）
                            icon = {
                                visible = "[OptionEffectItem.IsCritical]"
                                texture = "gfx/interface/icons/stress/icon_stress_gain_critical.dds"
                                name = "stress_critical"
                                size = { 34 34 }
                            }
                        }

                        # ---- 死亡效果图标 ----
                        icon = {
                            name = "death"
                            visible = "[OptionEffectItem.IsDeath]"
                            size = { 34 34 }
                            texture = "gfx/interface/icons/icon_dead.dds"  # 骷髅头图标
                        }

                        # ---- 阴谋效果图标 ----
                        icon = {
                            name = "scheme"
                            visible = "[OptionEffectItem.IsScheme]"
                            size = { 34 34 }
                            texture = "[OptionEffectItem.GetScheme.GetIcon]"  # 动态获取对应阴谋类型的图标
                        }
                    }
                }
            }
        }  # end hbox (主内容区)
    }  # end type
}  # end types