language_chinese = {
	type = language
	is_shown = {
		language_is_shown_trigger = {
			LANGUAGE = language_chinese
		}
	}
	ai_will_do = {
		value = 10
		if = {
			limit = { has_cultural_pillar = language_chinese }
			multiply = 10
		}
	}
	
	color = han
}

