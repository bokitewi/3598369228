#######################################################################
# 结构定义 
#######################################################################

### 概述: any_database_key  # 任意数据库键名（自定义配置的唯一标识）
# 风味化（Flavourization）是对名称和头衔的展示方式所做的定制化修改。
# 风味化配置的属性会按照本文档中列出的顺序依次校验。
# 一个风味化配置要生效，必须满足被评估角色的所有校验条件。
#
# 风味化配置的评估会涉及以下核心对象：
#   - 目标角色（Character）
#           即将应用该风味化配置的角色。
#   - 关联角色（Contextual Character）
#           被校验条件所指向的目标角色，即“触发头衔”的持有者。
#   - 触发头衔（Causing Title）
#           关联角色所持有的头衔。这是目标角色的“命名头衔”，
#           可能是目标角色自身的主要头衔，也可能是其配偶的主要头衔（取等级更高者）。
#   - 当前优先级（Current Priority）
#           分配给该风味化配置的优先级。只有当某风味化配置的优先级
#           高于此前已校验的配置时，才会被纳入评估范围。
#
# 除非另有说明，否则一个风味化配置要具备生效资格，必须满足**所有**校验条件。
#
# 若所有条件均满足，该风味化类型会调用与其名称相同的本地化键（localization key）进行文本展示。
#
flavourization_type = {  # 风味化配置的核心容器（所有规则都写在这个大括号内）

	### 类型: type (枚举类型)  # 配置适用的对象类型（决定校验逻辑的核心维度）
	# 该风味化配置适用于哪种类型的对象？部分校验条件并非适用于所有对象，
	# 相关限制会在对应字段的文档说明中标注。
	#
	# 有效值：
	#   character（角色）  # 最常用，用于角色头衔/名称的定制（如皇子、公主）
	#       该风味化配置作为头衔赋予角色。
	#       角色类风味化配置会进一步细分为不同子类别以简化检索流程：
	#       - 分级风味化（tiered flavour）：基于角色所属的实头衔等级（landed title tier）
	#       - 非分级风味化（non-tiered flavour）：与头衔等级无关
	#       上述两类又会根据下方定义的「special」字段，进一步细分出特殊风味化子组。
	#
	#       示例：
	#           皇帝（Emperor） vs. 至高王（High King）  # 不同等级的角色头衔差异
	#           小国王（Petty King） vs. 公爵（Duke）
	#
	#   title（头衔）  # 用于定制头衔本身的显示（如“汉帝国”而非“帝国”）
	#       该风味化配置用于标识头衔的等级，同样分为分级/非分级两类。
	#
	#       示例：
	#           公国（Duchy） vs. 小王国（Petty Kingdom）
	#           瑞士联邦（Swiss Confederation） vs. 奥地利大公国（Archduchy of Austria）
	#
	#   domicile（宅邸）  # 用于定制宅邸名称（如“太子府”“公主府”）
	#       该风味化配置应用于宅邸的展示文本。
	#
	#       示例：
	#           X的庄园（X's Estate） vs. X的庭院（X's Grounds）
	#
	type = character  # 示例值：配置仅适用于“角色”

	### 性别: gender (枚举类型)  # 限定配置生效的角色性别
	# 该风味化配置适用于男性还是女性角色？
	#
	# 仅当「type」为「character」时生效。
	#
	# 有效值：
	#   male（男性）  # 如皇子、太子
	#   female（女性）  # 如公主、郡主
	#
	gender = male  # 示例值：仅男性角色生效

	### 等级: tier (枚举类型)  # 限定配置生效的头衔等级（影响性能，慎用none）
	# 该风味化配置属于分级还是非分级类型？
	#
	# 若未设置等级（tier），则该配置可适用于所有等级的角色。
	# 但过多的非分级风味化配置会严重影响性能，特此警告！
	#
	# 仅当「type」为「character」或「title」时生效。
	#
	# 有效值：
	#   barony（男爵领）  # 最低等级
	#   county（伯爵领）
	#   duchy（公爵领）*注：原文「douchy」为拼写错误，修正为「duchy」
	#   kingdom（王国）
	#   empire（帝国）  # 最高等级（如汉帝国、唐帝国）
	#   none（无/非分级）  # 适用于所有等级，但性能差
	#
	tier = none  # 示例值：非分级（适用于所有头衔等级）

	### 特殊类型: special (枚举类型)  # 限定配置生效的角色特殊身份（优先校验）
	# 该配置是否为特殊类型的风味化？部分特殊类型会在常规风味化校验前
	# 优先检测，系统会找到第一个符合条件的特殊配置，再继续执行常规校验。
	#
	# 仅当「type」为「character」时生效。
	#
	# 有效值：
	#   head_of_faith（信仰领袖）  # 如教皇、大祭司
	#       适用于担任信仰领袖的角色。
	#
	#   councillor（内阁成员）  # 如丞相、将军
	#       适用于担任内阁职位的角色。
	#
	#   queen_mother（王太后）  # 如皇太后
	#       适用于未成年统治者的母亲。
	#
	#   ruler_child（统治者子嗣）  # 核心！皇子、公主、太子都用这个
	#       适用于统治者的子女。
	#
	#   domicile（宅邸持有者）  # 拥有宅邸的角色
	#       适用于自身或配偶拥有宅邸的角色。
	#
	#   holder（持有者）  # 默认值，所有角色都会触发该类型的校验
	#       默认值。这是最基础的类型，所有角色都会被校验。
	#
	special = holder  # 示例值：默认类型（所有角色都校验）

	### 优先级: priority (32位整数)  # 数值越高，配置越优先生效（避免冲突）
	# 为该风味化配置分配的静态优先级。系统会选择优先级最高的配置生效；
	# 若某配置的优先级低于已评估过的配置，则会被直接跳过。
	#
	priority = 1  # 示例值：优先级1（数值越大优先级越高，如皇子配置常用130/150）

	### 风味化规则: flavourization_rules (枚举位掩码容器)  # 核心生效规则（多条件组合）
	# 代码中会引用的风味化类型属性，按顺序依次评估。
	#
	flavourization_rules = {  # 规则容器（多个规则需同时满足）

		### 派系领袖: faction (布尔值)  # 是否限定为派系领袖
		# 默认值：no（否）
		# 启用后，该配置仅适用于担任派系领袖的角色，且「触发头衔」必须关联某个派系。
		#
		faction = no  # 示例值：不限制派系领袖

		### 仅独立统治者: only_independent (布尔值)  # 是否仅独立统治者生效（如皇帝，非附庸）
		# 默认值：no（否）
		# 启用后，该配置仅当「关联角色」为独立统治者时生效。
		#
		only_independent = no  # 示例值：不限制独立统治者

		### 配偶继承头衔: spouse_takes_title (布尔值)  # 配偶是否能继承该头衔显示
		# 默认值：yes（是）
		# 启用后，「关联角色」的配偶也可适用该风味化配置。
		#
		spouse_takes_title = yes  # 示例值：配偶可继承

		### 仅头衔持有者: only_holder (布尔值)  # 是否仅头衔本人生效（排除配偶/子女）
		# 启用后，该配置仅当「目标角色」与「关联角色」为同一人时生效（即目标角色是触发头衔的持有者）。
		#
		only_holder = no  # 示例值：不限制仅持有者

		### 最高宗主: top_liege (布尔值)  # 是否以最高宗主为校验目标（核心！皇子配置常用no）
		# 默认值：yes（是）
		# 启用后，所有涉及「关联角色」的校验会转而以其最高宗主为目标；
		# 禁用（no）则仅校验角色自身（如皇子配置：top_liege = no → 排除皇帝本人，仅子女生效）
		#
		top_liege = yes  # 示例值：默认校验最高宗主

		### 仅附庸: only_vassals (布尔值)  # 是否仅附庸角色生效（非独立统治者）
		# 默认值：no（否）
		# 启用后，该配置仅当「目标角色」非独立统治者时生效（即作为他人附庸）。
		#
		only_vassals = no  # 示例值：不限制仅附庸

		### 忽略最高宗主政体: ignore_top_liege_government (布尔值)  # 特殊规则：仅政体校验角色自身
		# 默认值：no（否）
		# 仅当top_liege规则启用（默认）时生效。
		# 启用后，除“政体”外，所有校验均以最高宗主为目标；政体校验仍以当前角色为准。
		#
		ignore_top_liege_government = no  # 示例值：不忽略
	}

	### 标记: flag (整数标记)  # 校验角色是否有指定标记（自定义标记需提前定义）
	# 关联角色是否拥有指定的标记？
	#
	flag = some_integer_flag  # 示例值：自定义整数标记（如1001=太子标记）

	### 政体: governments (数据库键数组)  # 限定生效的政体（如官僚制、部落制）
	# 关联角色必须拥有列表中的其中一种政体类型。
	#
	# 键名对应数据库路径：common/governments/ 
	#
	governments = { }  # 示例值：空数组（不限制政体），可填如bureaucracy_government（官僚制）

	### 宅邸类型: domicile_type (数据库键)  # 限定生效的宅邸类型（仅type=domicile时必填）
	# 关联角色必须拥有指定的宅邸类型。
	#
	# 仅当type为domicile时必填。
	#
	# 键名对应数据库路径：common/domiciles/ 
	#
	domicile_type = some_domicile_database_key  # 示例值：自定义宅邸键名（如taizi_mansion=太子府）

	### 名称列表: name_lists (数据库键数组)  # 限定生效的文化名称列表
	# 关联角色的文化必须属于列表中的某一个名称列表。
	#
	# 键名对应数据库路径：common/culture/name_lists 
	#
	name_lists = { }  # 示例值：空数组（不限制），可填如chinese_names（中文名称列表）

	### 文化传承: heritages (数据库键数组)  # 核心！限定生效的文化（如中华文化）
	# 关联角色的文化必须拥有列表中的某一种文化传承。
	#
	# 键名对应数据库路径：common/culture/pillars 
	#
	heritages = { }  # 示例值：空数组，常用值heritage_chinese（中华文化）

	### 信仰: faiths (数据库键数组)  # 限定生效的信仰（如儒教、佛教）
	# 关联角色的信仰必须属于列表中的某一个。
	#
	# 键名对应宗教数据库中的信仰模板：common/religion/religions
	# 	示例结构：
	# 	some_religion = { 
	#		... 
	#		faiths = { 
	#			faith_1 = { ... }  # 如confucianism=儒教
	#			faith_2 = { ... } 
	#		}
	#	}
	#
	faiths = { }  # 示例值：空数组（不限制信仰）

	### 宗教: religions (数据库键数组)  # 限定生效的宗教（比faiths范围更广）
	# 关联角色的信仰必须属于列表中的某一个。
	#
	# 键名对应宗教模板数据库：common/religion/religions 
	#
	religions = { }  # 示例值：空数组（不限制宗教）

	### 内阁职位: council_position (数据库键)  # 限定生效的内阁职位（如丞相）
	# 目标角色是否担任指定的内阁职位？
	#
	# 键名对应数据库路径：common/council_positions
	#
	council_position = council_position_key  # 示例值：chancellor=丞相

	### 法理宗主: de_jure_liege (数据库键数组)  # 限定触发头衔的法理宗主（如汉帝国）
	# 触发头衔是否隶属于指定头衔的法理范围？
	#
	# 键名对应实头衔数据库：common/landed_titles
	#
	de_jure_liege = { }  # 示例值：空数组，可填如e_han=汉帝国

	### 领地产物: holding (数据库键)  # 限定头衔的领地产物类型（仅type=title且tier=barony时生效）
	# 校验触发头衔对应的领地产物是否为指定类型。
	# 
	# 仅当type为title且tier为barony时生效。
	#
	# 键名对应数据库路径：common/holdings/ 
	#
	holding = holding_database_key  # 示例值：castle=城堡

	### 头衔: titles (数据库键数组)  # 限定生效的具体头衔（如e_han=汉帝国）
	# 触发头衔是否为列表中的某一个？ 
	#
	# 仅当type为character或title时生效。
	#
	# 键名对应实头衔数据库：common/landed_titles
	#
	titles = { }  # 示例值：空数组，可填如k_norway=挪威王国

	### 附庸契约义务标记: subject_contract_obligation_flags (标记数组)  # 限定附庸契约标记
	# 关联角色是否拥有列表中的某一个附庸契约标记？
	# 校验范围包括附庸契约、朝贡契约、税收槽位上的标记。
	#
	# 仅当type为character或title时生效。
	#
	# 契约数据路径：
	# common/subject_contracts/contracts
	# common/tax_slots/obligations
	#
	subject_contract_obligation_flags = { }  # 示例值：空数组（不限制）
}

#######################################################################
# 示例 
#######################################################################

# 示例功能：为挪威女王添加“霸气女王（Badass Queen）”的风味化头衔，
# 生效条件：她亲自持有挪威王国头衔 + 独立统治者 + 封建政体。
#
my_example_flavourization = {  # 自定义配置唯一标识（可改名为如han_queen）
	type = character  # 配置类型：角色
	gender = female  # 适用性别：女性
	priority = 1000  # 优先级：1000（极高，确保优先生效）
	titles = { k_norway }  # 限定头衔：挪威王国（k_norway）
	governments = { feudal_government }  # 限定政体：封建制
	
	flavourization_rules = {  # 生效规则（需同时满足）
		only_independent = yes  # 仅独立统治者生效
		only_holder = yes  # 仅头衔持有者本人生效（排除配偶/子女）
	}
}
my_example_flavourization: "Badass Queen"  # 本地化键：对应游戏内显示的文本（如“霸气女王”）