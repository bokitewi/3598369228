篡位测试 = { #
	picture = { reference = "gfx/interface/illustrations/decisions/tgp_kowtow.dds" }
    decision_group_type = SanGongLiuYuan
    desc = SanGong_ShouYang_decision_desc
    should_create_alert = { always = no }
    is_shown = {  
            is_ai = yes
	}
	is_valid = { 
            is_ai = no
	}
	effect = {
        clear_variable_list = QianChaoHuangDi_list	
        clear_variable_list = QianChaoPinFei_list	
        clear_variable_list = QianChaoZongShi_list	
            top_liege = {
                root = {
                    add_to_variable_list = {	
                        name = QianChaoHuangDi_list
                        target = prev
                    }
                }
                every_consort = {
                    root = {
                        add_to_variable_list = {	
                            name = QianChaoPinFei_list
                            target = prev
                        }
                    }
                }
                every_close_family_member = {
					limit = {
                        dynasty = top_liege.dynasty
						is_landed = no
					}
					root = {
                        add_to_variable_list = {	
                            name = QianChaoZongShi_list
                            target = prev
                        }
                    }
                }
            }
            close_all_views = yes
            set_global_variable = SanGong_CuanWei_Gobal
            set_global_variable = SanGong_CuanWei_main_1
	}
    ai_will_do = { base = 0 }
}	

