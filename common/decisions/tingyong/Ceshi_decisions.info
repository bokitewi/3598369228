            type = dushuxuexi
            save_scope_as = scheme
        }
        save_scope_as = owner
        trigger_event = SanGong_readIng_book.001
	}
    ai_check_interval = 6

	ai_potential = {
	}

	ai_will_do = {
		base = 0
	}
}

