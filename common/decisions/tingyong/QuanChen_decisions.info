    picture = { reference = "gfx/interface/illustrations/decisions/tgp_career.dds" }
    decision_group_type = SanGongLiuYuan
    desc = Quanchen_1_decision_desc
    should_create_alert = { always = no }
    is_shown = { 
       # NOT = {
            has_trait = SanGong_Quanchen
        #}
        is_ai = yes
        #is_independent_ruler = no
        highest_held_title_tier >= tier_kingdom
        NOR = {
            has_trait = loyal
            has_trait = craven
            has_trait = incapable
        }
    }
    is_valid = { 
        is_ai = no
       # prestige_level >= 4
       # is_independent_ruler = no
        highest_held_title_tier >= tier_kingdom
        NOR = {
            has_trait = loyal
            has_trait = craven
            has_trait = incapable
        }
    }	
    effect = {
            create_story = story_QuanChen
            save_scope_as = owned_story
            random_owned_story = {
                type = story_QuanChen
                set_variable = {
                    name = huangdi_character
                    value = scope:owned_story.top_liege
                }
                set_variable = {
                    name = Quanchen_character
                    value = scope:owned_story
                }
            }
    }
}


