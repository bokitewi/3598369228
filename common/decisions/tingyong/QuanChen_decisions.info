Quanchen_HE_decision = {#废立皇帝
    picture = { reference = "gfx/interface/illustrations/decisions/tgp_career.dds" }
    decision_group_type = SanGongLiuYuan
    desc = Quanchen_HE_decision_desc
    should_create_alert = { always = no }
    is_shown = { 
        has_trait = SanGong_Quanchen
        is_independent_ruler = no
        highest_held_title_tier >= tier_kingdom 
    }
    is_valid = { 
        has_trait = SanGong_Quanchen
        #prestige_level >= 4
        is_independent_ruler = no
        highest_held_title_tier >= tier_kingdom
    }	
    widget = {
		gui = "decision_view_widget_option_list_generic" # UI模板
		controller = decision_option_list_controller # 控制器
		decision_to_second_step_button = "diarch_attempt_to_overthrow_liege.second_step" # 第二步按钮
		item = {
			value = ShanRang_Duoquan # 选项值
			current_description = ShanRang_Duoquan_desc # 当前描述
			localization = ShanRang_Duoquan_tt # 本地化文本
			icon = "gfx/interface/icons/message_feed/diplomacy.dds" # 图标
			is_valid = { always = yes } # 始终可用
			# AI选择权重
			ai_chance = {
				value = 0 # 基础权重0
				# 条件：外交是最高属性，且外交≥勇武 → 权重+100
				if = {
					limit = {
						highest_skill = diplomacy
					}
					add = 100
				}
			}
		}
        item = {
			value = WuLi_Duoquan # 选项值
			current_description = WuLi_Duoquan_desc # 当前描述
			localization = WuLi_Duoquan_tt # 本地化文本
			icon = "gfx/interface/icons/icon_prowess.dds"
			is_valid = { always = yes } # 始终可用
			# AI选择权重
			ai_chance = {
				value = 0 # 基础权重0
				# 条件：外交是最高属性，且外交≥勇武 → 权重+100
				if = {
					limit = {
						highest_skill = prowess
					}
					add = 100
				}
			}
		}
	}
    effect = {
        liege = {
			# 选择外交政变 → 触发事件9001
			if = {
				limit = { scope:coup_diplomacy = yes }
				trigger_event = diarchy.9001
			}
			# 选择密谋政变 → 触发事件9011
			if = {
				limit = { scope:coup_intrigue = yes }
				trigger_event = diarchy.9011
			}
			# 选择勇武政变 → 触发事件9021
			if = {
				limit = { scope:coup_prowess = yes }
				trigger_event = diarchy.9021
			}
		}
	
        save_scope_as = recipient
        custom_tooltip = Quanchen_2_decision_tt
        trigger_event = SanGong_Quanchen_event.001
    }
}