```script
# ====================== 内阁职位 完整结构定义 注释版 ======================
# 语法格式：自定义内阁职位 = { 各项配置参数 }
name_of_the_position = {
	# 核心能力倾向：筛选人选时优先参考该属性
	# 不设置此项时，会默认按角色所有属性总和排序择优
	skill = diplomacy

	# 自动填充职位
	# 取值：yes / no / 触发器块
	# 作用：开启后系统自动指派人选，玩家无法手动选择任命对象
	# 作用域：内阁拥有者（领主本人），空触发器等价于 no
	# 默认值：no
	auto_fill = yes/no/{ <triggers> }

	# 从备选人才池选人
	# 取值：yes / no，默认 no
	# 生效前提：仅 auto_fill 开启或附带判定触发器时才生效
	# 关闭则从【宫廷成员+封臣】中选人，开启则优先从人才池选取
	fill_from_pool = yes/no

	# 是否为神职类职位
	# 取值：yes / no，默认 no
	# 作用：设为 yes 时，该职位人员会计入神职人员统计范畴
	is_clergy_position = yes/no

	# 职位世袭规则
	# 取值：yes / no / 触发器块
	# 作用：合法的第一顺位继承人可继承该内阁职位
	# 作用域：内阁拥有者，空触发器等价于 no
	# 默认值：no
	inherit = yes/no/{ <triggers> }

	# 是否可罢免该职位官员
	# 取值：yes / no / 触发器块
	# 作用域：内阁拥有者，空触发器等价于 yes
	# 默认值：yes
	can_fire = yes/no/{ <triggers> }

	# 是否可重新调任该职位官员
	# 取值：yes / no / 触发器块
	# 作用域：内阁拥有者，空触发器等价于 yes
	# 默认值：yes
	can_reassign = yes/no/{ <triggers> }

	# 单次任职限制
	# 取值：yes / no / 触发器块
	# 作用：角色一旦就任该职位，终生无法被罢免、调任
	# 作用域：内阁拥有者，空触发器等价于 no
	# 默认值：no
	can_change_once  = yes/no/{ <triggers> }

	# ---------------------- 本地化名称配置 ----------------------
	# 方式1：直接绑定本地化键，作为职位正式名称
	name = loc_key

	# 方式2：动态判定本地化名称（触发式文本）
	# 作用域：该官员的领主；事件目标 councillor = 现任官员
	# 无领主时，会降级使用职位默认键名，不再走动态文本逻辑
	name = {
		first_valid = { ... }
	}

	# ---------------------- 悬浮提示文本配置 ----------------------
	# 方式1：直接绑定本地化键，鼠标悬浮时显示的提示内容
	tooltip = loc_key

	# 方式2：动态判定悬浮提示（触发式文本）
	# 作用域：现任官员；事件目标 councillor_liege = 内阁拥有者/领主
	tooltip = {
		first_valid = { ... }
	}

	# ---------------------- 角色自身修正项 ----------------------
	# 任职者获得的属性/效果修正
	# 支持 scale 脚本值做倍率缩放，最多可定义5组 modifier
	modifier = {
	}

	# ---------------------- 领主修正项 ----------------------
	# 内阁领主（职位拥有者）获得的属性/效果修正
	# 支持 scale 脚本值做倍率缩放，最多可定义5组 council_owner_modifier
	council_owner_modifier = {
	}

	# ---------------------- 职位可用性判定 ----------------------
	# 判定【领主】是否拥有该职位（职位整体是否解锁）
	# 作用域：内阁拥有者（领主）
	valid_position = {

	}

	# ---------------------- 人选合法性判定 ----------------------
	# 判定【角色】是否有资格担任该职位
	# 生效场景：任命列表筛选、指派职位时都会触发校验
	# 作用域：候选/任职角色
	valid_character = {
	}

	# ---------------------- 职位相关事件/效果 ----------------------
	# 效果：角色成功就任该职位时触发
	# 作用域说明：
	# root = 就任职位的角色
	# councillor_liege = 内阁领主
	# swapped_position = 调换前的原职位（仅职位互换场景存在）
	on_get_position = {

	}

	# 效果：角色卸任该职位时触发
	# 执行顺序：被罢免时，此段会先于 on_fired_from_position 执行
	# 作用域说明：
	# root = 失去职位的角色
	# councillor_liege = 内阁领主
	on_lose_position = {
	
	}

	# 效果：角色被主动罢免时触发
	# 执行顺序：在 on_lose_position 之后运行
	# 作用域说明：
	# root = 被罢免的角色
	# councillor_liege = 内阁领主
	# new_councillor = 新任接任者（可能为空）
	on_fired_from_position = {

	}

	# ---------------------- 密谋相关配置 ----------------------
	# 是否将该职位人员属性计入【密谋阶段时长】计算
	use_for_scheme_phase_duration = yes/no

	# 是否将该职位人员属性计入【密谋抗性】计算
	use_for_scheme_resistance = yes/no

	# ---------------------- 头像动画配置 ----------------------
	# 内阁界面中，该职位角色使用的头像动画ID
	portrait_animation = X

	# ---------------------- 捏脸预设界面布局 ----------------------
	# 角色外观预设界面里，该内阁人员的显示布局参数
	barbershop_data = {
		# 角色站位坐标/位置配置
		position = { ... }
		# 点击该角色时，是否置顶显示（置于其他角色前方）
		click_to_front = yes/no
	}
}

# ====================== 相关本地化脚本函数 注释 ======================
# 获取角色当前担任的内阁职位名称，无职位则返回空
CHARACTER.GetCouncilTitle

# 获取内阁职位的所有格形式（如“XX的谋臣”），无职位则返回空
CHARACTER.GetCouncilTitlePossessive

# 传入职位键名+领主角色，查询角色担任该职位时对应的职位名称
CHARACTER.GetCouncilTitleForPosition('council_position_key', council_owner_character)

# 获取领主名下指定内阁职位的官员称谓，无官员则显示默认职位名
CHARACTER.GetMyCouncillorsTitle('council_position_key')

# 获取该内阁职位的默认本地化名称（文本键对应内容）
COUNCIL_POSITION.GetName

# 获取该内阁职位的原生键名（未本地化的脚本ID）
COUNCIL_POSITION.GetKey

# 获取该职位绑定的头像动画名称，无配置则使用全局默认动画
COUNCIL_POSITION.GetPortraitAnimation
